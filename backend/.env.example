# Copy this file to .env and fill in your values.

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/savi
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/savi
MONGODB_URI=mongodb://127.0.0.1:27017/savi

# Secret used to sign JWT auth tokens. Use any long random string.
JWT_SECRET=change_this_to_a_long_random_string

# Port the API listens on.
PORT=4000

# Optional: an OpenAI/Anthropic key enables live LLM suggestions.
# Leave blank — Savi's benchmark engine works fully without it.
LLM_API_KEY=
